# Copy to .env and set values for the connected controller.
# borunte0707a_driver reads this (via env_config.py) so ROS params default
# correctly. OS environment variables with the same names override these.

# Address the driver connects to on :9760 — the controller as reachable from
# the host RUNNING the driver. Run the driver on a host with a direct route to
# the controller (e.g. the Jetson wired to it); avoid forwarding :9760 across
# networks — the controller's socket pool is tiny and extra clients wedge it.
ROBOT_IP=
REMOTE_MONITOR_PORT=9760
# Read-only query timeout (telemetry/gate checks). Keep short: a stall blocks
# the publisher for this long. Motion sends use the bridge's command_timeout.
ROBOT_REQUEST_TIMEOUT_SECONDS=1.0
HC1_REMOTE_COMMAND_SERVICE_ID=www.hc-system.com.HCRemoteCommand

# Dev environment: ROS 2 Humble lives in WSL2 Ubuntu 22.04 (distro Ubuntu-22.04,
# not the default distro). Build/run there: `wsl -d Ubuntu-22.04`.
# Repo path inside WSL: /path/to/ros2_borunte_0707A
#
# Network path: dev machine --WiFi--> Jetson gateway --eth--> HC1 controller.
# Verify connectivity first with:  ros2 run borunte0707a_driver hc1_ping
